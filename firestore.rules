rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function ticketIdInRange(ticketId) {
      return ticketId.matches('^(276[6-9]|27[7-9][0-9]|2800)$');
    }

    function ticketIdMatchesNumber(ticketId, number) {
      return (ticketId == '2766' && number == 2766)
        || (ticketId == '2767' && number == 2767)
        || (ticketId == '2768' && number == 2768)
        || (ticketId == '2769' && number == 2769)
        || (ticketId == '2770' && number == 2770)
        || (ticketId == '2771' && number == 2771)
        || (ticketId == '2772' && number == 2772)
        || (ticketId == '2773' && number == 2773)
        || (ticketId == '2774' && number == 2774)
        || (ticketId == '2775' && number == 2775)
        || (ticketId == '2776' && number == 2776)
        || (ticketId == '2777' && number == 2777)
        || (ticketId == '2778' && number == 2778)
        || (ticketId == '2779' && number == 2779)
        || (ticketId == '2780' && number == 2780)
        || (ticketId == '2781' && number == 2781)
        || (ticketId == '2782' && number == 2782)
        || (ticketId == '2783' && number == 2783)
        || (ticketId == '2784' && number == 2784)
        || (ticketId == '2785' && number == 2785)
        || (ticketId == '2786' && number == 2786)
        || (ticketId == '2787' && number == 2787)
        || (ticketId == '2788' && number == 2788)
        || (ticketId == '2789' && number == 2789)
        || (ticketId == '2790' && number == 2790)
        || (ticketId == '2791' && number == 2791)
        || (ticketId == '2792' && number == 2792)
        || (ticketId == '2793' && number == 2793)
        || (ticketId == '2794' && number == 2794)
        || (ticketId == '2795' && number == 2795)
        || (ticketId == '2796' && number == 2796)
        || (ticketId == '2797' && number == 2797)
        || (ticketId == '2798' && number == 2798)
        || (ticketId == '2799' && number == 2799)
        || (ticketId == '2800' && number == 2800);
    }

    function allowedNumberKeys() {
      return [
        '2766', '2767', '2768', '2769', '2770', '2771', '2772',
        '2773', '2774', '2775', '2776', '2777', '2778', '2779',
        '2780', '2781', '2782', '2783', '2784', '2785', '2786',
        '2787', '2788', '2789', '2790', '2791', '2792', '2793',
        '2794', '2795', '2796', '2797', '2798', '2799', '2800'
      ];
    }

    function validBuyerName(data) {
      return data.buyerName is string
        && data.buyerName.size() >= 2
        && data.buyerName.size() <= 80;
    }

    function validTxid(data) {
      return data.txid is string
        && data.txid.matches('^[A-Z0-9]{1,25}$');
    }

    function validThirtyMinuteExpiry(data) {
      return data.expiresAt is timestamp
        && data.expiresAt > request.time
        && data.expiresAt <= request.time + duration.value(30, 'm');
    }

    function validOrderCreate() {
      return request.resource.data.keys().hasOnly([
          'buyerName',
          'ownerId',
          'status',
          'numberMap',
          'numbersText',
          'ticketCount',
          'amountCents',
          'ticketPriceCents',
          'txid',
          'expiresAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId is string
        && request.resource.data.status == 'pending'
        && validBuyerName(request.resource.data)
        && request.resource.data.numberMap is map
        && request.resource.data.numberMap.keys().size() >= 1
        && request.resource.data.numberMap.keys().size() <= 35
        && request.resource.data.numberMap.keys().hasOnly(allowedNumberKeys())
        && request.resource.data.ticketCount is int
        && request.resource.data.amountCents is int
        && request.resource.data.ticketPriceCents is int
        && request.resource.data.ticketCount == request.resource.data.numberMap.keys().size()
        && request.resource.data.ticketPriceCents == 2000
        && request.resource.data.amountCents == request.resource.data.ticketCount * 2000
        && request.resource.data.numbersText is string
        && request.resource.data.numbersText.size() >= 4
        && request.resource.data.numbersText.size() <= 250
        && validTxid(request.resource.data)
        && validThirtyMinuteExpiry(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validAdminOrderUpdate() {
      return isAdmin()
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'adminId',
          'confirmedAt',
          'rejectedAt',
          'updatedAt'
        ])
        && request.resource.data.status in ['confirmed', 'rejected']
        && request.resource.data.adminId == request.auth.uid
        && (
          (request.resource.data.status == 'confirmed'
            && request.resource.data.confirmedAt == request.time
            && resource.data.expiresAt > request.time)
          || (request.resource.data.status == 'rejected'
            && request.resource.data.rejectedAt == request.time)
        )
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.buyerName == resource.data.buyerName
        && request.resource.data.numberMap == resource.data.numberMap
        && request.resource.data.numbersText == resource.data.numbersText
        && request.resource.data.ticketCount == resource.data.ticketCount
        && request.resource.data.amountCents == resource.data.amountCents
        && request.resource.data.ticketPriceCents == resource.data.ticketPriceCents
        && request.resource.data.txid == resource.data.txid
        && request.resource.data.expiresAt == resource.data.expiresAt
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;
    }

    function validHoldWrite(holdId) {
      return request.resource.data.keys().hasOnly([
          'number',
          'ownerId',
          'orderId',
          'status',
          'expiresAt',
          'createdAt',
          'updatedAt'
        ])
        && ticketIdInRange(holdId)
        && request.resource.data.number is int
        && ticketIdMatchesNumber(holdId, request.resource.data.number)
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId is string
        && request.resource.data.status == 'pending'
        && request.resource.data.orderId is string
        && request.resource.data.orderId.size() > 0
        && request.resource.data.orderId.size() <= 80
        && existsAfter(/databases/$(database)/documents/orders/$(request.resource.data.orderId))
        && getAfter(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.ownerId == request.auth.uid
        && getAfter(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.status == 'pending'
        && getAfter(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.expiresAt == request.resource.data.expiresAt
        && getAfter(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.numberMap[holdId] == true
        && validThirtyMinuteExpiry(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validTicketWrite(ticketId) {
      return request.resource.data.keys().hasOnly([
          'number',
          'buyerName',
          'status',
          'amountCents',
          'orderId',
          'adminId',
          'createdAt',
          'confirmedAt',
          'updatedAt'
        ])
        && ticketIdInRange(ticketId)
        && request.resource.data.number is int
        && ticketIdMatchesNumber(ticketId, request.resource.data.number)
        && request.resource.data.status == 'paid'
        && request.resource.data.amountCents is int
        && request.resource.data.amountCents == 2000
        && request.resource.data.orderId is string
        && request.resource.data.orderId.size() > 0
        && request.resource.data.orderId.size() <= 80
        && request.resource.data.adminId == request.auth.uid
        && validBuyerName(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.confirmedAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    match /admins/{adminId} {
      allow read: if signedIn() && request.auth.uid == adminId;
      allow write: if false;
    }

    match /orders/{orderId} {
      allow read: if signedIn()
        && (isAdmin() || resource.data.ownerId == request.auth.uid);
      allow create: if signedIn() && validOrderCreate();
      allow update: if validAdminOrderUpdate();
      allow delete: if false;
    }

    match /holds/{holdId} {
      allow read: if signedIn();
      allow create: if signedIn() && validHoldWrite(holdId);
      allow update: if signedIn()
        && resource.data.expiresAt is timestamp
        && resource.data.expiresAt <= request.time
        && validHoldWrite(holdId);
      allow delete: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if signedIn();
      allow create: if isAdmin() && validTicketWrite(ticketId);
      allow update: if false;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
